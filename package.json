{
  "name": "baseapi-cl",
  "version": "0.2.0",
  "description": "SDK oficial de BaseAPI.cl — API SII Chile para emitir facturas electrónicas (DTE), boletas de honorarios (BHE), boletas de terceros (BTE) y consultar RCV, cesiones, F22, carpeta tributaria y declaraciones juradas desde Node.js / TypeScript",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && echo '{\"type\":\"module\"}' > dist/esm/package.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "sii",
    "sii-chile",
    "chile",
    "tax",
    "impuestos",
    "factura",
    "factura-electronica",
    "facturacion-electronica",
    "dte",
    "documento-tributario-electronico",
    "boleta",
    "boleta-honorarios",
    "bhe",
    "boleta-terceros",
    "bte",
    "honorarios",
    "rcv",
    "registro-compras-ventas",
    "cesiones",
    "factoring",
    "carpeta-tributaria",
    "f22",
    "formulario-22",
    "declaracion-juradas",
    "dj",
    "nota-credito",
    "nota-debito",
    "guia-despacho",
    "api",
    "sdk",
    "typescript",
    "nodejs",
    "baseapi",
    "contabilidad",
    "tributario"
  ],
  "author": "Tecnológica Chile <contacto@tecnologicachile.cl>",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/tecnologicachile/baseapi-sdk.git"
  },
  "homepage": "https://api.baseapi.cl/docs/client",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.0.0"
  }
}
